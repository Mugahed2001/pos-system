# Frontend production environment variables (do not commit secrets)
EXPO_PUBLIC_API_BASE_URL=https://pos-system-ciq8.onrender.com/api
EXPO_PUBLIC_DEVICE_ID=POS-DEVICE-RENDER
# Set a real device token in the hosting provider dashboard
EXPO_PUBLIC_DEVICE_TOKEN=change-me
# Optional: default branch id for demo
EXPO_PUBLIC_BRANCH_ID=
# Enable POS WebSocket connection (if backend supports channels/ASGI websocket)
EXPO_PUBLIC_ENABLE_POS_WS=true
