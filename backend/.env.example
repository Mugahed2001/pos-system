DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOW_ALL=true
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,http://localhost:8081,http://localhost:8082,http://127.0.0.1:19006,http://127.0.0.1:8081,http://127.0.0.1:8082
DJANGO_CORS_ALLOW_CREDENTIALS=true
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:19006,http://localhost:8081,http://localhost:8082,http://127.0.0.1:19006,http://127.0.0.1:8081,http://127.0.0.1:8082
DJANGO_PAGE_SIZE=50
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_SECURE_PROXY_SSL_HEADER=false

# PostgreSQL required (no SQLite fallback)
# Database URL (overrides DB_* if set)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DB_SCHEMA=pos_loc

# Backend API host/port (for desktop launcher)
API_HOST=127.0.0.1
API_PORT=8000

# Database fields (used when DATABASE_URL is empty)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=pos
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_CONNECT_TIMEOUT=10
DB_SSLMODE=disable
DB_STATEMENT_TIMEOUT_MS=15000
